{
  "nodes": [
    {
      "id": "node_1",
      "type": "fileInput",
      "position": { "x": 100, "y": 300 },
      "data": { 
        "label": "Historical Betting Data", 
        "category": "inout", 
        "icon": "FileText", 
        "parameters": { "filePath": "data_historical.csv", "fileType": "csv" } 
      }
    },
    {
      "id": "node_2",
      "type": "select",
      "position": { "x": 350, "y": 300 },
      "data": { 
        "label": "Select Columns", 
        "category": "prep", 
        "icon": "List", 
        "parameters": { 
          "columns": [
            { "name": "Date", "keep": true },
            { "name": "Competition", "keep": true },
            { "name": "HomeTeam", "keep": true },
            { "name": "AwayTeam", "keep": true },
            { "name": "FT_HomeScore", "keep": true, "rename": "HomeGoals", "type": "Float64" },
            { "name": "FT_AwayScore", "keep": true, "rename": "AwayGoals", "type": "Float64" },
            { "name": "FT_HomeOdds", "keep": true, "rename": "HomeOdds", "type": "Float64" },
            { "name": "FT_AwayOdds", "keep": true, "rename": "AwayOdds", "type": "Float64" }
          ]
        } 
      }
    },
    {
      "id": "node_3",
      "type": "formula",
      "position": { "x": 600, "y": 300 },
      "data": { 
        "label": "Calculate Total Goals", 
        "category": "prep", 
        "icon": "Calculator", 
        "parameters": { "output_column": "TotalGoals", "expression": "[HomeGoals] + [AwayGoals]" } 
      }
    },
    {
      "id": "node_4",
      "type": "filter",
      "position": { "x": 850, "y": 300 },
      "data": { 
        "label": "High Scoring (>= 4)?", 
        "category": "prep", 
        "icon": "Filter", 
        "parameters": { "filterType": "custom", "customExpression": "[TotalGoals] >= 4" } 
      }
    },
    {
      "id": "node_5",
      "type": "sort",
      "position": { "x": 1100, "y": 150 },
      "data": { 
        "label": "Sort High Scoring", 
        "category": "prep", 
        "icon": "ArrowUpDown", 
        "parameters": { "column": "TotalGoals", "descending": true } 
      }
    },
    {
      "id": "node_6",
      "type": "visualization",
      "position": { "x": 1350, "y": 150 },
      "data": { 
        "label": "High Score Plot", 
        "category": "analysis", 
        "icon": "BarChart2", 
        "parameters": { "chartType": "scatter", "xAxis": "HomeOdds", "yAxis": "AwayOdds", "colorBy": "Competition", "title": "Odds of High Scoring Matches" } 
      }
    },
    {
      "id": "node_7",
      "type": "summarize",
      "position": { "x": 1100, "y": 450 },
      "data": { 
        "label": "Avg Goals per Team", 
        "category": "prep", 
        "icon": "Sigma", 
        "parameters": { 
          "group_by": ["HomeTeam"], 
          "agg_column": "TotalGoals",
          "agg_function": "mean",
          "output_name": "AvgHomeMatchGoals"
        } 
      }
    },
    {
      "id": "node_8",
      "type": "sort",
      "position": { "x": 1350, "y": 450 },
      "data": { 
        "label": "Sort by Avg Goals", 
        "category": "prep", 
        "icon": "ArrowUpDown", 
        "parameters": { "column": "AvgHomeMatchGoals", "descending": true } 
      }
    },
    {
      "id": "node_9",
      "type": "visualization",
      "position": { "x": 1600, "y": 450 },
      "data": { 
        "label": "Avg Goals By Team", 
        "category": "analysis", 
        "icon": "BarChart2", 
        "parameters": { "chartType": "bar", "xAxis": "HomeTeam", "yAxis": "AvgHomeMatchGoals", "title": "Avg Goals per Team (Low Scoring)" } 
      }
    }
